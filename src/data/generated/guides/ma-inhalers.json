  "glossary": [
    {
      "term": "Prior authorization (PA)",
      "short": "Insurer sign-off needed before the drug is covered.",
      "definition": "A requirement that the prescriber get the plan's approval before it will pay for a drug. Until it's approved, the pharmacy claim rejects — which is the round-trip this tool helps you skip.",
      "sourceIds": [
        "mh-pa37"
      ]
    },
    {
      "term": "BOGL (brand over generic)",
      "short": "The plan forces the brand; the generic rejects.",
      "definition": "Some plans prefer a specific brand and won't cover its generic equivalent. You must write the brand and mark \"dispense as written\" or the pharmacy claim rejects. Example: MassHealth prefers brand Ventolin over generic albuterol.",
      "sourceIds": [
        "mh-mhdl-t23"
      ]
    },
    {
      "term": "Step therapy",
      "short": "Must fail a preferred drug first.",
      "definition": "The plan requires the patient to try (and fail, or be intolerant of) one or more preferred drugs before it will cover the one you want.",
      "sourceIds": [
        "mh-pa37"
      ]
    },
    {
      "term": "Dispense as written (DAW)",
      "short": "Tell the pharmacy not to substitute a generic.",
      "definition": "A note on the prescription instructing the pharmacist to dispense the exact brand you wrote, not a generic substitute. Needed when the plan's BOGL rule forces the brand.",
      "sourceIds": []
    },
    {
      "term": "SABA — rescue inhaler",
      "short": "Quick-relief inhaler for sudden symptoms.",
      "definition": "Short-acting beta-agonist. The inhaler a patient carries and uses when they suddenly can't breathe well. Works in minutes; not a daily controller.",
      "sourceIds": [
        "nhlbi-asthma",
        "ncbi-albuterol"
      ]
    },
    {
      "term": "ICS — daily controller",
      "short": "A daily steroid inhaler that calms inflammation.",
      "definition": "Inhaled corticosteroid. Taken every day to keep the airways from getting inflamed and twitchy. It prevents attacks; it does not relieve one in progress.",
      "sourceIds": [
        "nhlbi-asthma"
      ]
    },
    {
      "term": "Generic vs. biosimilar",
      "short": "Inhalers have generics; biologics have biosimilars.",
      "definition": "Inhalers are small-molecule drugs, so cheaper copies are FDA-approved \"generics\" (e.g., Wixela Inhub for Advair). Injectable biologics like Xolair get \"biosimilars\" instead (e.g., Omlyclo) — a different FDA pathway.",
      "sourceIds": [
        "fda-wixela",
        "fda-biosimilars"
      ]
    }
  ],
