{
  "name": "firstpassrx",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Find the preferred inhaler per Massachusetts payer and avoid Prior Authorization round-trips.",
  "homepage": "https://pranava0x0.github.io/FirstPassRx/",
  "scripts": {
    "data:split": "node scripts/split-formulary.mjs",
    "predev": "npm run data:split",
    "dev": "vite",
    "prebuild": "npm run data:split",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "pretest": "node scripts/split-formulary.mjs --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "trace": "node scripts/trace-sources.mjs",
    "trace:live": "node scripts/trace-sources.mjs --live",
    "build:map": "node scripts/build-map.mjs",
    "archive-sources": "node scripts/archive-sources.mjs",
    "validate-links": "node scripts/validate-links.cjs",
    "validate-prices": "node scripts/validate-prices.mjs",
    "validate-prices:live": "node scripts/validate-prices.mjs --live",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist -t"
  },
  "dependencies": {
    "jspdf": "4.2.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.0.1",
    "@testing-library/user-event": "14.5.2",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "6.0.2",
    "gh-pages": "6.2.0",
    "jsdom": "25.0.1",
    "typescript": "5.6.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}
