# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# Vite / test caches
.vite/
coverage/
*.tsbuildinfo

# Intermediate formulary-gathering checkpoints (see .claude/skills/formulary-data)
data-gathering/

# Archived source documents (scripts/archive-sources.mjs): committed for durability across
# sessions/worktrees. Not under public/ and never imported by app code, so Vite's build never
# picks these up -- safe to commit without shipping them to the deployed site.

# Secrets (none expected in this static app, but never commit them)
.env
.env.local
.env.*.local
credentials.json
secrets/

# Editor / OS
.DS_Store
*.local
.idea/
.vscode/*
!.vscode/extensions.json

# Logs
*.log
npm-debug.log*
